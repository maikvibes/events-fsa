# --- API Gateway ---
PORT=3000

# --- Kafka ---
# The host:port the app uses to bootstrap. In the docker network this is the
# SSL-enabled listener (kafka:29093). Override per environment if needed.
KAFKA_BROKER=kafka:29093

# --- Redis ---
# In-cluster: connect directly to the redis container on the docker network.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
# External (from host): connect via nginx on port 6380.
# REDIS_HOST=cache.maik.io.vn
# REDIS_PORT=6380

# --- Postgres (one instance, three DBs) ---
# In-cluster (docker network): services connect directly to postgres:5432.
AUTH_DATABASE_URL=postgresql://auth_app:__SET_ME__@postgres:5432/auth_db?schema=public
EVENTS_DATABASE_URL=postgresql://events_app:__SET_ME__@postgres:5432/events_db?schema=public
NOTIFICATIONS_DATABASE_URL=postgresql://notifications_app:__SET_ME__@postgres:5432/notifications_db?schema=public
# External (from host / CI for Prisma migrations): connect via nginx on port 5433.
# NOTIFICATIONS_DATABASE_URL=postgresql://notifications_app:__SET_ME__@db-notif.maik.io.vn:5433/notifications_db?schema=public

# --- TLS settings for the app ---
# Postgres
DATABASE_SSL_MODE=require
DATABASE_SSL_CA_PATH=/etc/ssl/events-fsa/ca.crt

# Kafka (in-cluster apps): SSL listener, no SASL required.
KAFKA_SECURITY_PROTOCOL=SSL
KAFKA_SSL_CA_PATH=/etc/ssl/events-fsa/ca.crt

# Public hostname nginx proxies to the SASL_SSL Kafka listener (port 9094).
# Must match the SAN in the Kafka server cert — set before running
# scripts/generate-certs.sh so the cert is issued for this hostname.
KAFKA_EXTERNAL_HOSTNAME=nginx.maik.io.vn
POSTGRES_EXTERNAL_HOSTNAME=db-notif.maik.io.vn
REDIS_EXTERNAL_HOSTNAME=cache.maik.io.vn

# External client credentials for the SASL_SSL listener (kafka-app user).
# These are NOT used by the in-cluster NestJS apps (they use the SSL listener).
# Distribute to external producers/consumers that connect via nginx:9094.
# KAFKA_SASL_MECHANISM=SCRAM-SHA-256
# KAFKA_SASL_USERNAME=kafka_app
# KAFKA_SASL_PASSWORD=

# Redis
REDIS_TLS=true
REDIS_TLS_CA_PATH=/etc/ssl/events-fsa/ca.crt

# --- Firebase Cloud Messaging ---
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# --- Auth ---
JWT_SECRET=change-me-in-production
