# API Gateway
PORT=3000

# Kafka
KAFKA_BROKER=localhost:9092

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Postgres (one instance, three DBs)
AUTH_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_db?schema=public
EVENTS_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/events_db?schema=public
NOTIFICATIONS_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/notifications_db?schema=public

# Firebase Cloud Messaging
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# Auth
JWT_SECRET=change-me-in-production
